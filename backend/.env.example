DATABASE_URL=postgresql://stockintel:stockintel@localhost:5432/stockintel
DB_HOST=localhost
DB_PORT=5432
DB_USER=stockintel
DB_PASSWORD=stockintel
DB_NAME=stockintel

# Server
NODE_ENV=development
PORT=3001

# Allowed frontend origins for CORS.
# Use a comma-separated list for multiple origins (e.g. local + Vercel preview + production).
CORS_ORIGIN=http://localhost:5173

# JWT Secret (required for auth)
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# Market Data Provider: 'rapidapi', 'twelvedata', 'polygon', etc.
# RapidAPI provides access to Yahoo Finance data through their API
MARKET_DATA_PROVIDER=rapidapi

# RapidAPI Configuration (for Yahoo Finance via RapidAPI)
# Get your API key from https://rapidapi.com/
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=yahoo-finance15.p.rapidapi.com

# Twelve Data API (alternative provider)
# Get your API key from https://twelvedata.com/
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# Other market data providers (optional)
FMP_API_KEY=your_fmp_key_here
EODHD_API_KEY=your_eodhd_key_here
POLYGON_API_KEY=your_polygon_key_here
SEC_EDGAR_API_KEY=your_sec_edgar_key_here
SIMFIN_API_KEY=your_simfin_key_here

# Apify API (for NSE Kenya market data via wafspaul/nse-kenya-market-data actor)
# Get your API token from https://console.apify.com/
APIFY_API_KEY=your_apify_api_key_here

# Redis Configuration (for message queuing and signal caching)
REDIS_URL=redis://localhost:6379

# Signal Publisher Interval (how often to generate and publish signals, in ms)
SIGNAL_INTERVAL_MS=30000

# Logging
LOG_REQUESTS=1
LOG_LEVEL=info

# --- Email Delivery ---
# Priority: Ensend API > SMTP (Nodemailer) > Ethereal test emails
#
# Ensend (https://ensend.co) - Multi-channel messaging API
# Set ENSEND_PROJECT_SECRET to use Ensend (sends email/SMS/push via REST API)
# Get your secret from: Workspace > Project > Credentials
ENSEND_PROJECT_SECRET=
ENSEND_SENDER_NAME=StocksIntels
ENSEND_SENDER_ADDRESS=
# ENSEND_BASE_URL=https://api.ensend.co

# SMTP / Email Configuration (fallback when Ensend is not configured)
# Leave both unset to use Ethereal test emails (preview URLs in console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="StocksIntels <noreply@yourdomain.com>"

# PayHero M-Pesa Integration
# Get your auth token and channel ID from https://app.payhero.co.ke
PAYHERO_BASE_URL=https://backend.payhero.co.ke/api/v2
PAYHERO_AUTH_TOKEN=your_payhero_basic_auth_token
PAYHERO_CHANNEL_ID=your_channel_id
# Callback URL must be publicly accessible (use ngrok for local dev)
PAYHERO_CALLBACK_URL=https://your-public-domain.com

# PayPal (replaces card payments)
# Get API keys from https://developer.paypal.com/dashboard/applications
# Use sandbox for testing, live for production
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# Public-facing URLs for PayPal redirects (use ngrok for local dev)
PAYPAL_RETURN_URL=https://your-public-domain.com
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id  # Optional - for webhook verification
FRONTEND_URL=http://localhost:5173

# Broker Credential Encryption (required)
# Generate a strong 32-byte key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BROKER_ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Triple-A Crypto Payments (https://www.triple-a.io)
# Get API credentials from Triple-A dashboard
TRIPLE_A_MODE=sandbox
TRIPLE_A_CLIENT_ID=your_triple_a_client_id
TRIPLE_A_CLIENT_SECRET=your_triple_a_client_secret