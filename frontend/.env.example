# Backend API URL used by the Vite frontend.
# Local dev: http://localhost:3001/api
# Production: https://your-render-service.onrender.com/api
VITE_API_URL=http://localhost:3001/api

# Google OAuth Client ID for Sign-In
# Get one at: https://console.cloud.google.com/apis/credentials
# Add your Vercel preview/production URLs as Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Frontend market data / news API keys (set in Vercel dashboard, not here)
# VITE_NEWSAPI_KEY=your_newsapi_key_here
# VITE_FINNHUB_KEY=your_finnhub_key_here
# VITE_POLYGON_API_KEY=your_polygon_key_here
# VITE_BENZINGA_API_KEY=your_benzinga_key_here
